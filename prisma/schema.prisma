generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Article {
  id           String        @id @default(uuid())
  title        String
  content      String        @db.Text
  url          String?
  imageUrl     String?       @map("image_url")
  category     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isRead       Boolean       @default(false)
  isBookmarked Boolean       @default(false)
  scheduledFor DateTime?
  score        ArticleScore?

  @@index([category])
  @@index([createdAt])
}

model Comment {
  id         String   @id @default(uuid())
  articleId  String
  authorName String   @default("Anonymous")
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([articleId])
}

model ArticleScore {
  id            String   @id @default(uuid())
  articleId     String   @unique
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  substance     Int      @default(0)
  depth         Int      @default(0)
  structure     Int      @default(0)
  vocabulary    Int      @default(0)
  readability   Int      @default(0)
  specificity   Int      @default(0)
  actionability Int      @default(0)
  engagement    Int      @default(0)
  total         Int      @default(0)
  socialScore   Int      @default(0)
  updatedAt     DateTime @default(now())

  @@index([socialScore])
  @@index([total])
}

model Post {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  url       String?
  imageUrl  String?  @map("image_url")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Book {
  id        String   @id @default(uuid())
  title     String
  author    String
  url       String?
  imageUrl  String?  @map("image_url")
  review    String?  @db.Text
  rating    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WishlistItem {
  id        String   @id @default(uuid())
  name      String
  price     String?
  url       String?
  imageUrl  String?  @map("image_url")
  priority  String   @default("Low")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Song {
  id        String         @id @default(uuid())
  title     String
  audioUrl  String         @map("audio_url")
  source    String         @default("youtube") // youtube, local, etc
  duration  Int? // seconds
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  playlists PlaylistSong[]
  radios    RadioSong[]
}

model Radio {
  id          String      @id @default(uuid())
  slug        String      @unique
  name        String
  description String?
  themeColor  String      @default("#3b82f6")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  songs       RadioSong[]
}

model RadioSong {
  radioId String
  songId  String
  radio   Radio  @relation(fields: [radioId], references: [id], onDelete: Cascade)
  song    Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([radioId, songId])
}

model Playlist {
  id          String         @id @default(uuid())
  slug        String         @unique
  title       String
  description String?
  philosophy  String?
  schedule    String?
  vibes       String[]
  coverColor  String?
  coverImage  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  songs       PlaylistSong[]
}

model PlaylistSong {
  playlistId String
  songId     String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song       Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([playlistId, songId])
}
