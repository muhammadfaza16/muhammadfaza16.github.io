generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Article {
  id           String        @id @default(uuid())
  title        String
  content      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isRead       Boolean       @default(false)
  scheduledFor DateTime?
  imageUrl     String?       @map("image_url")
  url          String?
  category     String?
  isBookmarked Boolean       @default(false)
  score        ArticleScore?

  @@index([category])
  @@index([createdAt])
}

model Comment {
  id         String   @id @default(uuid())
  articleId  String
  authorName String   @default("Anonymous")
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([articleId])
}

model ArticleScore {
  id            String   @id @default(uuid())
  articleId     String   @unique
  substance     Int      @default(0)
  depth         Int      @default(0)
  structure     Int      @default(0)
  vocabulary    Int      @default(0)
  readability   Int      @default(0)
  specificity   Int      @default(0)
  actionability Int      @default(0)
  engagement    Int      @default(0)
  total         Int      @default(0)
  updatedAt     DateTime @default(now())
  socialScore   Int      @default(0)
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([socialScore])
  @@index([total])
}

model Post {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  imageUrl  String?  @map("image_url")
  url       String?
}

model Book {
  id        String   @id @default(uuid())
  title     String
  author    String
  review    String?
  rating    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  imageUrl  String?  @map("image_url")
  url       String?
}

model WishlistItem {
  id        String   @id @default(uuid())
  name      String
  price     String?
  url       String?
  priority  String   @default("Low")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  imageUrl  String?  @map("image_url")
}

model Song {
  id        String         @id @default(uuid())
  title     String
  audioUrl  String         @map("audio_url")
  source    String         @default("youtube")
  duration  Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  playlists PlaylistSong[]
}

model Playlist {
  id          String         @id @default(uuid())
  slug        String         @unique
  title       String
  description String?
  philosophy  String?
  schedule    String?
  vibes       String[]
  coverColor  String?
  coverImage  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  songs       PlaylistSong[]
}

model PlaylistSong {
  playlistId String
  songId     String
  order      Int      @default(0)
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song       Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([playlistId, songId])
}

model MusicAccessLog {
  id        String   @id @default(uuid())
  ip        String
  city      String?
  country   String?
  region    String?
  isp       String?
  userAgent String?
  timestamp DateTime @default(now())
}
